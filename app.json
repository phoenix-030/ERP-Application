{
  "expo": {
    "name": "STUDENT-ERP",
    "slug": "erp-college",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "studenterp",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/images/applogo.png",
    "ios": {
      "icon": "./assets/images/applogo.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/applogo.png",
        "backgroundImage": "./assets/images/applogo.png",
        "monochromeImage": "./assets/images/applogo.png",
        "backgroundColor": "#2563eb"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.codexcraft030.EduConnect"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#2563eb",
          "image": "assets/images/applogo.png",
          "resizeMode": "contain"
        }
      ],
      "expo-image",
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e2e56b96-7e88-42f0-8de9-f8bf97cea94c"
      }
    },
    "owner": "harisho3"
  }
}
